@model Link
<h2>Add Link</h2>
<form asp-action="AddLink" method="post">
    <input type="hidden" asp-for="CategoryId" />
    <div class="form-group">
        <label asp-for="TitleRu"></label>
        <input asp-for="TitleRu" class="form-control" required />
    </div>
    <div class="form-group">
        <label asp-for="TitleZh"></label>
        <input asp-for="TitleZh" class="form-control" required />
    </div>
    <div class="form-group">
        <label asp-for="Url"></label>
        <input asp-for="Url" class="form-control" required />
    </div>
    <div class="form-group">
        <label asp-for="DescriptionRu"></label>
        <textarea asp-for="DescriptionRu" class="form-control"></textarea>
    </div>
    <div class="form-group">
        <label asp-for="DescriptionZh"></label>
        <textarea asp-for="DescriptionZh" class="form-control"></textarea>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>