@model Category
<h2>Add Category</h2>
<form asp-action="AddCategory" method="post">
    <div class="form-group">
        <label asp-for="NameRu"></label>
        <input asp-for="NameRu" class="form-control" required />
    </div>
    <div class="form-group">
        <label asp-for="NameZh"></label>
        <input asp-for="NameZh" class="form-control" required />
    </div>
    <button type="submit" class="btn btn-primary mt-2">Save</button>
    <a asp-action="Index" class="btn btn-secondary mt-2">Cancel</a>
</form>