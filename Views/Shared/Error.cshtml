@model ErrorViewModel
@{
    ViewData["Title"] = "Ошибка";
}

<h1 class="text-danger">Ошибка</h1>
<h2 class="text-danger">Произошла ошибка при обработке вашего запроса.</h2>

@if (Model?.ShowRequestId ?? false)
{
<p>
    <strong>Request ID:</strong> <code>@Model?.RequestId</code>
</p>
}

<p class="text-muted">
    <small>Попробуйте обновить страницу или вернуться на <a href="/">главную</a>.</small>
</p>