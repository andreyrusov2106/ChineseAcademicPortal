@model IEnumerable<ChineseAcademicPortal.Models.VakJournal>
@{
    ViewData["Title"] = "Каталог ВАК-журналов";
}

<div class="container py-4">
    <h1>📚 Каталог журналов ВАК РФ</h1>
    <p class="text-muted">Рецензируемые журналы, подходящие для публикации статей по диссертации</p>

    <!-- Фильтры -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-3 align-items-end">
                
                <!-- Фильтр по индексации -->
                <div class="col-md-4">
                    <label class="form-label small text-muted">Тип индексации</label>
                    <select name="indexType" class="form-select">
                        <option value="">Все журналы</option>
                        <option value="ВАК" selected="@(ViewBag.IndexType == "ВАК")">Только ВАК/РИНЦ</option>
                        <option value="Scopus" selected="@(ViewBag.IndexType == "Scopus")">Scopus</option>
                        <option value="WoS" selected="@(ViewBag.IndexType == "WoS")">Web of Science</option>
                        <option value="Scopus+WoS" selected="@(ViewBag.IndexType == "Scopus+WoS")">Scopus + WoS</option>
                    </select>
                </div>

                <!-- Поиск по названию -->
                <div class="col-md-6">
                    <label class="form-label small text-muted">Поиск по названию</label>
                    <input type="text" name="topic" value="@ViewBag.SelectedTopic" 
                           class="form-control" placeholder="Например: физика, медицина, вестник...">
                </div>

                <!-- Кнопка -->
                <div class="col-md-2 d-grid">
                    <button type="submit" class="btn btn-primary">🔍 Найти</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Результаты -->
    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-warning">
            По выбранным фильтрам журналы не найдены. 
            <a asp-action="Index" class="alert-link">Сбросить фильтры</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Название журнала</th>
                        <th>ISSN</th>
                        <th>Индексация</th>
                        <th>Сайт</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var j in Model)
                    {
                        <tr>
                            <td>
                                <strong>@j.NameRu</strong>
                                @if (!string.IsNullOrEmpty(j.NameEn))
                                {
                                    <br/><small class="text-muted">@j.NameEn</small>
                                }
                            </td>
                            <td><span class="badge bg-secondary">@j.Issn</span></td>
                            <td>
                                @if (!string.IsNullOrEmpty(j.Note))
                                {
                                    @foreach (var tag in j.Note.Split(',').Select(t => t.Trim()))
                                    {
                                        <span class="badge bg-warning text-dark me-1">@tag</span>
                                    }
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(j.Url))
                                {
                                    <a href="@j.Url" target="_blank" rel="noopener" class="btn btn-sm btn-outline-primary">🌐</a>
                                }
                                else
                                {
                                    <span class="text-muted small">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <small class="text-muted">📊 Найдено: @Model.Count() журналов</small>
    }

    <div class="alert alert-light border mt-4">
        <small class="text-muted">
            ⚠️ Список обновляется автоматически. Перед подачей статьи проверьте актуальность на 
            <a href="https://vak.minobrnauki.gov.ru" target="_blank">vak.minobrnauki.gov.ru</a>
        </small>
    </div>
</div>