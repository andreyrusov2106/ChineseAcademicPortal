@model List<ChineseAcademicPortal.Models.VakJournal>
@{
    ViewData["Title"] = "Каталог ВАК-журналов";
    
    // Простая локализация без .resx (можно позже вынести в ресурсы)
    var texts = System.Globalization.CultureInfo.CurrentCulture.Name switch
    {
        "zh-CN" or "zh" => new {
            Title = "ВАК期刊目录",
            Description = "俄罗斯高等认证委员会认可的学术期刊，可用于博士论文答辩",
            FilterCategory = "按类别筛选",
            FilterTopic = "按主题筛选",
            AllCategories = "所有类别",
            AllTopics = "所有主题",
            Apply = "应用",
            Reset = "重置",
            Name = "期刊名称",
            ISSN = "ISSN",
            Topics = "主题",
            Website = "网站",
            Note = "备注",
            NoResults = "未找到符合条件的期刊",
            Disclaimer = "⚠️ 列表仅供参考。提交论文前请务必在官方渠道验证期刊状态: "
        },
        _ => new {
            Title = "Каталог журналов ВАК РФ",
            Description = "Рецензируемые журналы из списка ВАК, подходящие для публикации статей по диссертации",
            FilterCategory = "Фильтр по категории",
            FilterTopic = "Фильтр по теме",
            AllCategories = "Все категории",
            AllTopics = "Все темы",
            Apply = "Применить",
            Reset = "Сбросить",
            Name = "Название журнала",
            ISSN = "ISSN",
            Topics = "Тематика",
            Website = "Сайт",
            Note = "Примечание",
            NoResults = "По выбранным фильтрам журналы не найдены",
            Disclaimer = "⚠️ Список носит ознакомительный характер. Перед подачей статьи обязательно проверьте актуальность журнала на официальном сайте: "
        }
    };
}

<div class="container py-4">
    <h1>@texts.Title</h1>
    <p class="text-muted">@texts.Description</p>

    <!-- Фильтры -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label small text-muted">@texts.FilterCategory</label>
                    <select name="category" class="form-select">
                        <option value="">@texts.AllCategories</option>
                        @foreach (var cat in ViewBag.Categories)
                        {
                            <option value="@cat" selected="@(ViewBag.SelectedCategory == cat)">@cat</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label small text-muted">@texts.FilterTopic</label>
                    <select name="topic" class="form-select">
                        <option value="">@texts.AllTopics</option>
                        @foreach (var t in ViewBag.Topics)
                        {
                            <option value="@t" selected="@(ViewBag.SelectedTopic == t)">@t</option>
                        }
                    </select>
                </div>
                <div class="col-md-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">@texts.Apply</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">@texts.Reset</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Результаты -->
    @if (!Model.Any())
    {
        <div class="alert alert-warning">@texts.NoResults</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>@texts.Name</th>
                        <th>@texts.ISSN</th>
                        <th>@texts.Topics</th>
                        <th>@texts.Website</th>
                        <th>@texts.Note</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var j in Model)
                    {
                        <tr>
                            <td>
                                <strong>@j.NameRu</strong><br/>
                                @if (!string.IsNullOrEmpty(j.NameEn))
                                {
                                    <small class="text-muted">@j.NameEn</small>
                                }
                            </td>
                            <td><span class="badge bg-secondary">@j.Issn</span></td>
                            <td>
                                @if (!string.IsNullOrEmpty(j.Topics))
                                {
                                    @foreach (var t in j.Topics.Split(',').Select(x => x.Trim()))
                                    {
                                        <a asp-action="Index" asp-route-topic="@t" class="badge bg-info text-decoration-none me-1">@t</a>
                                    }
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(j.Url))
                                {
                                    <a href="@j.Url" target="_blank" class="btn btn-sm btn-outline-primary">🌐</a>
                                }
                            </td>
                            <td><small class="text-muted">@j.Note</small></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <!-- Дисклеймер -->
    <div class="alert alert-light border mt-4">
        <small class="text-muted">
            @texts.Disclaimer <a href="https://vak.minobrnauki.gov.ru" target="_blank">vak.minobrnauki.gov.ru</a>
        </small>
    </div>
</div>